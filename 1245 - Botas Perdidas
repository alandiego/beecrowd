#include <bits/stdc++.h>

using namespace std;

int main(){
    ios::sync_with_stdio(0);
    cin.tie(0);
    cout.tie(0);
    
    int botasE[31], botasD[31];
    int N;
    
    while (cin >> N){
        memset(botasE, 0, sizeof(botasE));
        memset(botasD, 0, sizeof(botasD));
        while (N--){
            int tam; char pe;
            cin >> tam >> pe;
            tam = tam-30;
            if (pe == 'E')
                botasE[tam]++;
            else
                botasD[tam]++;
        }
        int pares=0;
        for (int i=0; i<=30; i++){
            pares+= min(botasE[i], botasD[i]);
        }
        cout << pares << '\n';
    }
    
    return 0;
}

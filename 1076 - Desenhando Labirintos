#include <bits/stdc++.h>
using namespace std;

typedef pair<int, int> ii;


int main() {
    int N;
    
    cin >> N;

	

	while (N--) {
	    int s, V, E;
	
		cin >> s >> V >> E;
		set<ii> EL;
		for (int i = 0; i < E; ++i) {
			int u, v;
			cin >> u >> v;
			EL.insert({min(u, v), max(u, v)});

		}
		
		cout << EL.size()*2 << '\n';
		
		
	}
	return 0;
}

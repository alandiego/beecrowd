#include <bits/stdc++.h>

using namespace std;

vector<string> numeros = {"one", "two", "three"};

int verifica(string &valor){
    for (int i=0; i<3; i++){
        int dif=0;
        for (int j=0; j<numeros[i].size(); j++){
            if (numeros[i][j] != valor[j])
                dif++;
        }
        if (dif<=1)
            return ++i;
    }
    return 0;
}

int main (){
    int N;
    
    cin >> N;
    
    while (N--){
        string valor;
        cin >> valor;
        cout << verifica(valor) << '\n';
    }
}
